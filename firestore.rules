rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Artículos (feed) ─────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.authorId;

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Propiedades (alquiler) ────────────────────────────────────────────────
    match /properties/{propertyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.ownerId;

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Usuarios ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /following/{followingId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Notificaciones — solo el dueño puede leer/escribir
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Reseñas ───────────────────────────────────────────────────────────────
    // La query whereEqualTo("userId", uid) requiere que CUALQUIER documento que
    // pueda coincidir sea legible. Por eso el allow read es para todos los
    // usuarios autenticados (no solo el dueño).
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;

      match /likes/{likerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == likerId;
      }
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    // ── Fixers (Assistant) ────────────────────────────────────────────────────
    // Datos de demo para el modo asistente: cualquier usuario autenticado puede
    // leerlos y sembrarlos. Separados de /users/ porque allí las reglas exigen
    // que el ID del documento coincida con el UID del usuario, lo que impediría
    // crear perfiles de fixers con IDs deterministas.
    match /fixers/{fixerId} {
      allow read, write: if request.auth != null;
    }

    // ── Checkout / reservas ───────────────────────────────────────────────────
    match /checkouts/{checkoutId} {
      allow read: if request.auth != null
          && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
